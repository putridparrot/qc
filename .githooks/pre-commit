#!/usr/bin/env sh
set -eu

echo "[qc pre-commit] cargo fmt --all -- --check"
cargo fmt --all -- --check

echo "[qc pre-commit] cargo clippy --all-targets --all-features -- -D warnings"
cargo clippy --all-targets --all-features -- -D warnings

echo "[qc pre-commit] cargo test --all-features --quiet"
cargo test --all-features --quiet

echo "[qc pre-commit] all checks passed"
